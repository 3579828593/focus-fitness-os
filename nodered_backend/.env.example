# Focus Fitness OS - Environment Variables Template
#
# Copy this file to .env.local and fill in real values:
#   cp .env.local.example .env.local
#
# Generate secure secrets:
#   node -e "const c=require('crypto'); console.log('NODE_RED_SECRET=' + c.randomBytes(32).toString('hex')); console.log('JWT_SECRET=' + c.randomBytes(32).toString('hex'));"
#
# Generate bcrypt hash for Node-RED editor password:
#   node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 8))"
#
# Generate scrypt hash for API login password:
#   node -e "const c=require('crypto'); const s=c.randomBytes(16); const h=c.scryptSync('YOUR_PASSWORD', s, 64); console.log(s.toString('hex')+':'+h.toString('hex'));"
#
# IMPORTANT: .env.local is in .gitignore and MUST NOT be committed to the repository.

# Node-RED credential encryption secret (64-char hex string)
NODE_RED_SECRET=

# JWT signing secret for API authentication (64-char hex string)
JWT_SECRET=

# Node-RED editor admin password (bcrypt hash, $2a$ or $2b$ format)
NODE_RED_ADMIN_HASH=

# CORS allowed origins (comma-separated, no spaces)
# Default: GitHub Pages + localhost
CORS_ALLOWED_ORIGINS=https://3579828593.github.io,http://127.0.0.1:1880,http://localhost:1880
