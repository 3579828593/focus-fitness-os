# ============================================
# Focus Fitness OS - 环境变量模板
# 复制为 .env 并填入实际值
# ============================================

# Node-RED 凭证加密密钥 (生产环境必须修改)
NODE_RED_SECRET=change-this-to-a-random-string

# Telegram Bot 通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP 邮件通知
SMTP_USER=
SMTP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587

# Pushover 推送通知
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Node-RED 管理员密码 (bcrypt 哈希)
# 使用 node-red-admin hash-pw 生成
ADMIN_PASSWORD_HASH=
API_PASSWORD_HASH=
