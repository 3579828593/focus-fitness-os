# ============================================
# Focus Fitness OS - Oracle Cloud Environment
# Copy to .env and fill in your values
# ============================================

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=replace_with_your_jwt_secret_min_32_chars

# Node-RED Admin Secret (generate with: openssl rand -hex 16)
NODE_RED_SECRET=replace_with_your_nodered_secret

# Domain (for TLS certificate)
DOMAIN=your-domain.example.com

# Oracle Cloud Instance Config
ORACLE_REGION=ap-tokyo-1
ORACLE_COMPARTMENT_OCID=ocid1.compartment.oc1..your-compartment
ORACLE_INSTANCE_OCID=ocid1.instance.oc1.ap-tokyo-1.your-instance

# SSH Key Path (for deployment scripts)
SSH_KEY_PATH=~/.ssh/oracle_cloud_key
SSH_USER=ubuntu
INSTANCE_PUBLIC_IP=your.instance.public.ip
