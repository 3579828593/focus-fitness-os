{
  "name": "focus-fitness-os-nodered",
  "version": "1.0.0",
  "description": "Focus Fitness OS - Node-RED 后端编排服务，负责番茄钟、健身训练、日程调度与通知推送",
  "private": true,
  "scripts": {
    "start": "node-red -u . -s settings.js",
    "debug": "node-red -u . -s settings.js --verbose",
    "test": "mocha test/**/*.test.js --timeout 5000"
  },
  "dependencies": {
    "node-red-contrib-cron-plus": "^2.1.0",
    "node-red-contrib-google-calendar": "^0.0.4",
    "node-red-contrib-telegrambot": "^1.9.0",
    "node-red-contrib-wger": "^0.2.0",
    "node-red-node-email": "^3.0.0",
    "node-red-node-pushover": "^0.0.5",
    "node-red-node-sqlite": "^1.1.0"
  },
  "devDependencies": {
    "mocha": "^10.8.2",
    "node-red-node-test-helper": "^0.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "node-red",
    "focus",
    "fitness",
    "pomodoro",
    "wger",
    "automation"
  ],
  "license": "MIT"
}
